# Last.fm now-playing widget
# 1. Get an API key: https://www.last.fm/api/account/create
# 2. Make sure your YouTube Music plays are scrobbling to Last.fm (Web Scrobbler)
LASTFM_API_KEY=
LASTFM_USERNAME=

# Telegram chat bridge
# 1. Create a bot with @BotFather -> token
# 2. Start your bot, then set your numeric chat id here
# 3. Webhook secret: any random string (used to verify Telegram requests)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis (stores chat sessions + messages) — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
